---
layout: base.njk
content_css: |
  article { max-width: 680px; margin: 0 auto; padding: 9rem 2rem 3rem; }
  .post-tag { font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; }
  article h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 2.8rem); line-height: 1.18; color: var(--gold-light); margin-bottom: 2.5rem; }
  article h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--gold-light); margin: 2.5rem 0 1rem; }
  article p { font-size: 16px; line-height: 1.85; color: var(--muted); margin-bottom: 1.4rem; }
  article em { color: var(--gold-light); font-style: italic; }
  article a { color: var(--gold); }
  article hr { border: none; height: 1px; background: var(--darker); margin: 3rem 0; }
  .signoff { font-size: 14px; color: var(--dim); font-style: italic; }
  .signoff a { color: var(--gold); }
---
<article>
  <div class="post-tag">{{ date | readableDate }}</div>
  {{ content | safe }}
</article>
